{
  "name": "sportelo-reservations-scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape": "tsx src/index.ts",
    "summary": "tsx src/bin/summary.ts",
    "worker": "tsx src/bin/worker.ts",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@notionhq/client": "^2.3.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "node-cron": "^3.0.3",
    "p-limit": "^6.1.0",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.29.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
